PORT=3000
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:8080

# Database (provided by platform in prod)
DATABASE_URL=postgresql://robin:robin_dev@localhost:5432/robin_dev

# Redis (provided by platform in prod)
REDIS_URL=redis://localhost:6379

# better-auth
BETTER_AUTH_SECRET=change-me-32-chars-minimum-padding
BETTER_AUTH_URL=http://localhost:3000

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Keypair encryption
KEY_ENCRYPTION_SECRET=change-me-32-chars-minimum-padding

# Gateway (HMAC secret must match GATEWAY_HMAC_SECRET in gateway config)
GATEWAY_URL=http://localhost:9000
GATEWAY_HMAC_SECRET=change-me-same-value-on-both-server-and-gateway

# AI (OpenRouter — agent-side key for all LLM calls)
OPENROUTER_AGENT_KEY=
ROBIN_MODEL=anthropic/claude-sonnet-4-6

# Debug (set to 1 for verbose request/response/queue logging)
# DEBUG=1
