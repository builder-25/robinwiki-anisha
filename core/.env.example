# === Server ===
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
APP_URL=http://localhost:3000

# === Database ===
DATABASE_URL=postgresql://postgres@127.0.0.1:5432/robinwiki

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Auth ===
# 32+ chars. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-32-chars-minimum-padding

# === Crypto ===
# 64 hex chars. Generate with: openssl rand -hex 32
MASTER_KEY=
# 32+ chars for key encryption
KEY_ENCRYPTION_SECRET=

# === Initial User ===
INITIAL_USERNAME=you@example.com
INITIAL_PASSWORD=change-me

# === AI ===
# Get from openrouter.ai/keys
OPENROUTER_API_KEY=

# === Frontend ===
# Wiki UI origin for CORS
WIKI_ORIGIN=http://localhost:8080
