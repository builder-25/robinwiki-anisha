PORT=3000
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:8080

# Database (provided by platform in prod)
DATABASE_URL=postgresql://postgres@localhost:5432/robin_dev

# Redis (provided by platform in prod)
REDIS_URL=redis://localhost:6379

# better-auth
BETTER_AUTH_SECRET=change-me-32-chars-minimum-padding
BETTER_AUTH_URL=http://localhost:3000

# Crypto envelope — 64 hex chars. Generate with: openssl rand -hex 32
MASTER_KEY=

# Single-user seed credentials (used by seed-first-user on first boot)
INITIAL_USERNAME=you@example.com
INITIAL_PASSWORD=change-me

# AI (OpenRouter — all LLM calls go through this key)
OPENROUTER_API_KEY=
ROBIN_MODEL=anthropic/claude-sonnet-4-6

# Debug (set to 1 for verbose request/response/queue logging)
# DEBUG=1
