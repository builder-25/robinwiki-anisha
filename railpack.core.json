{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": { "node": "20" },
  "steps": {
    "install": {
      "commands": [
        "corepack enable",
        "corepack prepare pnpm@10.15.1 --activate",
        "pnpm install --frozen-lockfile"
      ]
    },
    "build": {
      "commands": ["pnpm --filter @robin/core... build"]
    }
  },
  "deploy": {
    "base": { "image": "ghcr.io/railwayapp/railpack-runtime:mise-2026.3.17" },
    "inputs": [
      { "step": "packages:mise", "include": ["/mise/shims", "/mise/installs", "/etc/mise"] },
      { "step": "install", "include": ["node_modules", "packages/shared/node_modules", "packages/agent/node_modules", "packages/queue/node_modules", "core/node_modules"] },
      { "step": "build", "include": ["."] }
    ],
    "startCommand": "/mise/shims/node core/dist/index.js"
  }
}
