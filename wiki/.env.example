# Robin API server (used by next.config.ts rewrites for /api/*)
# Prod: set to your internal/private core service URL, e.g. http://core.railway.internal:3000
ROBIN_SERVER=http://localhost:3000

# Used by server-side auth calls in src/lib/auth-client.ts (SSR context)
NEXT_PUBLIC_APP_URL=http://localhost:8080
