{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": { "node": "20" },
  "steps": {
    "install": {
      "inputs": [{ "include": ["."] }],
      "commands": [
        "corepack enable",
        "corepack prepare pnpm@10.15.1 --activate",
        "pnpm install --frozen-lockfile"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }, { "include": ["."] }],
      "secrets": ["NEXT_PUBLIC_ROBIN_API"],
      "commands": ["pnpm --filter @robin/wiki... build"]
    }
  },
  "deploy": {
    "base": { "image": "ghcr.io/railwayapp/railpack-runtime:mise-2026.3.17" },
    "inputs": [
      { "step": "packages:mise", "include": ["/mise/shims", "/mise/installs", "/etc/mise"] },
      { "step": "install", "include": ["node_modules", "packages/shared/node_modules", "wiki/node_modules"] },
      { "step": "build", "include": ["."] }
    ],
    "startCommand": "cd wiki && /mise/shims/node node_modules/next/dist/bin/next start -p $PORT"
  }
}
